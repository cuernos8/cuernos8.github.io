function legHTML(leg){
  const price = leg.price ? `<span class="leg-chip">${leg.price}</span>` : '';
  const tag = leg.tag ? `<span class="leg-tag">${leg.tag}</span>` : '';
  const link = leg.link ? `<a class="leg-link" href="${leg.link}" target="_blank" rel="noopener">Ver más ↗</a>` : '';
  return `<div class="leg">
    <span class="leg-icon">${leg.icon}</span>
    <span class="leg-text">${leg.text}</span>
    ${leg.meta?`<span class="leg-meta">${leg.meta}</span>`:''}
    ${price}${tag}${link}
  </div>`;
}
function hotelHTML(h){
  if(!h) return '';
  if(h.repeat){
    return `<div class="hotel-row hotel-repeat">🏨 <strong>${h.name}</strong> · ${h.place} <span class="repeat-tag">misma noche</span></div>`;
  }
  return `<div class="hotel-row">
    <div class="hotel-main">🏨 <strong>${h.name}</strong> · ${h.place}</div>
    <div class="hotel-meta"><span class="hotel-price">${h.price}</span><span class="hotel-status">${h.status}</span></div>
  </div>`;
}
function extraHTML(extra){
  if(!extra) return '';
  const items = extra.items.map(i=>`<li>${i}</li>`).join('');
  return `<details class="extra-box"><summary>${extra.title}</summary><ul>${items}</ul></details>`;
}
function dayCardHTML(d){
  return `<li class="timeline-item" data-country="${d.country}">
    <div class="day-badge">
      <span class="day-num">${d.day}</span>
      <span class="day-date">${d.date}</span>
    </div>
    <div class="day-card">
      <div class="day-card-head">
        <h3>${d.route}</h3>
        <span class="kind-pill">${d.kind}</span>
      </div>
      <div class="legs">${d.legs.map(legHTML).join('')}</div>
      ${d.note?`<p class="day-note">${d.note}</p>`:''}
      ${hotelHTML(d.hotel)}
      ${extraHTML(d.extra)}
    </div>
  </li>`;
}
document.getElementById('itin-list').innerHTML = ITINERARY.map(dayCardHTML).join('');
document.getElementById('budget-body').innerHTML = BUDGET.map(b=>`<tr><td>${b.concept}</td><td>${b.total}</td><td>${b.pp}</td></tr>`).join('');

