  if(window.storage){
    try{
      const res = await window.storage.get(STORAGE_KEY, false);
      if(res && res.value) return JSON.parse(res.value);
      return {};
    }catch(e){ return {}; }
  }
  return memoryChecked;
}
let saveTimer = null;
function saveChecked(obj){
  memoryChecked = obj;
  if(window.storage){
    clearTimeout(saveTimer);
    saveTimer = setTimeout(async ()=>{
      try{ await window.storage.set(STORAGE_KEY, JSON.stringify(obj), false); }
      catch(e){ console.error('No se pudo guardar la checklist', e); }
    }, 200);
  }
}

function itemHTML(catId, item, checked){
  const fullId = catId+'__'+item.id;
  const isChecked = checked[fullId] ? 'checked' : '';
  return `<label class="check-item">
    <input type="checkbox" data-id="${fullId}" ${isChecked}>
    <span class="box" aria-hidden="true"></span>
    <span class="lbl">${item.label}</span>
  </label>`;
}
function categoryHTML(cat, checked){
  let body = '';
  if(cat.items){
    body = cat.items.map(it=>itemHTML(cat.id, it, checked)).join('');
  } else if(cat.groups){
    body = cat.groups.map(g=>
      `<p class="group-label">${g.label}</p>` + g.items.map(it=>itemHTML(cat.id, it, checked)).join('')
    ).join('');
  }
  return `<div class="cat-card" data-cat="${cat.id}">
    <div class="cat-head"><span class="cat-emoji">${cat.emoji}</span><h3>${cat.name}</h3><span class="cat-count"></span></div>
    <div class="cat-body">${body}</div>
  </div>`;
}
function renderChecklist(checked){
  document.getElementById('checklist-grid').innerHTML = CHECKLIST.map(c=>categoryHTML(c, checked)).join('');
}

function progressMessage(pct){
  if(pct===0) return 'Todavía no has metido nada en la maleta 🧳';
  if(pct<40) return 'Vas empezando… ¡a por todas! 💪';
  if(pct<80) return 'Buen ritmo, sigue así 🌴';
  if(pct<100) return 'Ya casi está… 🧴✨';
  return '¡Maleta lista! Solo falta el billete 🛫🎉';
}
function fireConfetti(){
  const layer = document.getElementById('confetti-layer');
  const pieces = ['🎉','🌴','☀️','🧳','✈️','🌺'];
  for(let i=0;i<22;i++){
    const span = document.createElement('span');
    span.className='confetti-piece';
    span.textContent = pieces[Math.floor(Math.random()*pieces.length)];
    span.style.left = Math.random()*100+'vw';
    span.style.animationDuration = (2 + Math.random()*1.5)+'s';
    span.style.fontSize = (1 + Math.random()*0.8)+'rem';
    layer.appendChild(span);
    setTimeout(()=>span.remove(), 4000);
  }
}
function updateProgress(){
  const all = document.querySelectorAll('#checklist-grid input[type=checkbox]');
  const done = document.querySelectorAll('#checklist-grid input[type=checkbox]:checked');
  const total = all.length, n = done.length;
  const pct = total ? Math.round(n/total*100) : 0;
  document.getElementById('progress-fill').style.width = pct+'%';
  document.getElementById('progress-text').textContent = `${n} / ${total} preparado · ${pct}%`;
  document.getElementById('progress-msg').textContent = progressMessage(pct);
  document.querySelectorAll('.cat-card').forEach(card=>{
    const cAll = card.querySelectorAll('input[type=checkbox]');
    const cDone = card.querySelectorAll('input[type=checkbox]:checked');
    const span = card.querySelector('.cat-count');
    if(span) span.textContent = `${cDone.length}/${cAll.length}`;
  });
  if(pct===100 && !confettiShown){ fireConfetti(); confettiShown = true; }
  if(pct<100) confettiShown = false;
}

(async function initChecklist(){
  let checked = await loadChecked();
  renderChecklist(checked);
  updateProgress();
  document.getElementById('checklist-grid').addEventListener('change', (e)=>{
    const input = e.target.closest('input[type=checkbox]');
    if(!input) return;
    checked[input.dataset.id] = input.checked;
    saveChecked(checked);
    updateProgress();
  });
  document.getElementById('reset-checklist').addEventListener('click', ()=>{
    if(!confirm('¿Reiniciar toda la checklist? Se desmarcará todo.')) return;
    checked = {};
    saveChecked(checked);
    renderChecklist(checked);
    updateProgress();
  });
})();
</script>
</body>
