const tabButtons = Array.from(document.querySelectorAll('nav.tabs button'));
const panels = {
  portada: document.getElementById('panel-portada'),
  itinerario: document.getElementById('panel-itinerario'),
  checklist: document.getElementById('panel-checklist')
};
function activateTab(name){
  tabButtons.forEach(btn=>{
    const isSel = btn.dataset.tab === name;
    btn.setAttribute('aria-selected', isSel ? 'true':'false');
    btn.tabIndex = isSel ? 0 : -1;
  });
  Object.entries(panels).forEach(([key,panel])=>{
    if(key===name){panel.hidden=false; panel.classList.add('active');}
    else {panel.hidden=true; panel.classList.remove('active');}
  });
}
tabButtons.forEach(btn=>{
  btn.addEventListener('click', ()=>activateTab(btn.dataset.tab));
});
document.querySelector('nav.tabs').addEventListener('keydown', (e)=>{
  if(e.key!=='ArrowRight' && e.key!=='ArrowLeft') return;
  const i = tabButtons.findIndex(b=>b.getAttribute('aria-selected')==='true');
  const next = e.key==='ArrowRight' ? (i+1)%tabButtons.length : (i-1+tabButtons.length)%tabButtons.length;
  tabButtons[next].focus();
  activateTab(tabButtons[next].dataset.tab);
});

/* ============================================================
   COUNTDOWN
   ============================================================ */
const TARGET = new Date('2026-08-05T09:00:00+02:00').getTime();
function pad(n){return String(n).padStart(2,'0');}
function setUnit(id, value){
  const el = document.getElementById(id);
  const text = pad(value);
  if(el.textContent !== text){
    el.textContent = text;
    el.classList.add('tick');
    setTimeout(()=>el.classList.remove('tick'), 250);
  }
}
function updateCountdown(){
  const diff = TARGET - Date.now();
  if(diff <= 0){
    document.getElementById('flip-board').style.display='none';
    document.getElementById('departed-msg').style.display='block';
    document.getElementById('mini-cd-days').textContent = '0';
    return;
  }
  const totalSec = Math.floor(diff/1000);
  const days = Math.floor(totalSec/86400);
  const hours = Math.floor(totalSec%86400/3600);
  const mins = Math.floor(totalSec%3600/60);
  const secs = totalSec%60;
  setUnit('cd-days', days);
  setUnit('cd-hours', hours);
  setUnit('cd-mins', mins);
  setUnit('cd-secs', secs);
  document.getElementById('mini-cd-days').textContent = days;
}
updateCountdown();
setInterval(updateCountdown, 1000);

