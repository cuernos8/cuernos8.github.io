# cuernos8.github.io
theme: Cabo-Verde-Bidaia
title: Cabo Verde Bidaia
description: Bidaiaren egitaraua
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cabo Verde Bidaia</title>
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E%F0%9F%8F%9D%EF%B8%8F%3C/text%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Caveat:wght@500;600;700&family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
/* ============ TOKENS ============ */
:root{
  --paper:#FBF1E2;
  --paper-deep:#F1E2C7;
  --ink:#20303D;
  --ink-soft:#5C6C76;
  --coral:#E8536F;
  --coral-deep:#BD3953;
  --coral-tint:#FBE2E6;
  --gold:#EFA431;
  --gold-deep:#C97D14;
  --gold-tint:#FBEAD0;
  --teal:#1C9C8E;
  --teal-deep:#0E6F65;
  --teal-tint:#DCF0EA;
  --violet:#8C5FBF;
  --card:#FFFBF3;
  --line:rgba(32,48,61,.16);
  --shadow:0 14px 34px -16px rgba(32,48,61,.35);
  --radius:18px;
  --font-display:'Fraunces',serif;
  --font-hand:'Caveat',cursive;
  --font-body:'Plus Jakarta Sans',sans-serif;
  --font-mono:'Space Mono',monospace;
}
*{box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{
  margin:0;
  font-family:var(--font-body);
  color:var(--ink);
  background-color:var(--paper);
  background-image:
    radial-gradient(circle at 1px 1px, rgba(32,48,61,.06) 1px, transparent 1.6px);
  background-size:22px 22px;
  -webkit-font-smoothing:antialiased;
}
img{max-width:100%;display:block;}
a{color:var(--teal-deep);}
button{font-family:inherit;}
:focus-visible{outline:3px solid var(--coral);outline-offset:2px;border-radius:4px;}
.sr-only{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);}

@media (prefers-reduced-motion: reduce){
  *{animation-duration:.001ms !important; transition-duration:.001ms !important;}
}

/* ============ HEADER / NAV ============ */
header.site{
  position:sticky; top:0; z-index:50;
  background:var(--paper-deep);
  border-bottom:1px solid var(--line);
  padding:10px 18px;
}
.header-inner{
  max-width:1080px; margin:0 auto;
  display:flex; align-items:center; justify-content:space-between;
  gap:14px; flex-wrap:wrap;
}
.brand{
  display:flex; align-items:center; gap:8px;
  font-family:var(--font-display); font-weight:700; font-size:1.05rem;
  letter-spacing:.2px; white-space:nowrap;
}
.brand .flag{font-size:1.2rem;}
.mini-countdown{
  font-family:var(--font-mono); font-size:.72rem; letter-spacing:.5px;
  background:var(--ink); color:var(--gold-tint);
  border-radius:999px; padding:5px 11px;
  display:inline-flex; align-items:center; gap:6px;
}
.mini-countdown b{color:#fff; font-size:.82rem;}
.brand-row{display:flex; align-items:center; gap:12px;}

nav.tabs{
  display:flex; gap:6px; background:rgba(32,48,61,.06);
  padding:4px; border-radius:14px;
}
nav.tabs button{
  border:none; background:transparent; cursor:pointer;
  padding:8px 14px; border-radius:11px;
  font-size:.86rem; font-weight:600; color:var(--ink-soft);
  display:flex; align-items:center; gap:6px;
  transition:background .2s,color .2s;
}
nav.tabs button[aria-selected="true"]{
  background:var(--card); color:var(--ink);
  box-shadow:0 3px 10px -4px rgba(32,48,61,.4);
}
nav.tabs button:hover{color:var(--ink);}

/* ============ LAYOUT ============ */
main{max-width:1080px; margin:0 auto; padding:28px 18px 80px;}
.panel{display:none;}
.panel.active{display:block; animation:fadeIn .35s ease;}
@keyframes fadeIn{from{opacity:0; transform:translateY(6px);} to{opacity:1; transform:translateY(0);}}

/* ============ PORTADA ============ */
.hero-frame{
  border-radius:26px; overflow:hidden; box-shadow:var(--shadow);
  border:1px solid var(--line);
  position:relative;
}
.hero-frame img{width:100%; height:auto; display:block;}
.hero-cap{
  font-family:var(--font-mono); font-size:.68rem; letter-spacing:1px;
  text-align:right; color:var(--ink-soft); margin:8px 4px 0;
}

.title-block{text-align:center; margin:38px auto 6px; position:relative;}
.title-block h1{
  font-family:var(--font-display); font-weight:800;
  font-size:clamp(2.3rem, 7vw, 4.6rem); margin:0; line-height:1.02;
  color:var(--ink);
}
.title-block h1 span{color:var(--coral);}
.underline-doodle{display:block; width:min(420px,80%); margin:6px auto 0;}
.tagline{
  font-family:var(--font-hand); font-size:clamp(1.3rem,3vw,1.7rem);
  color:var(--teal-deep); margin:10px 0 0; font-weight:600;
}

.ticket-wrap{position:relative; max-width:560px; margin:40px auto 10px;}
.doodle-corner{position:absolute; opacity:.85;}
.doodle-corner.tl{top:-26px; left:-28px; width:54px;}
.doodle-corner.br{bottom:-22px; right:-22px; width:40px;}
@media (max-width:480px){.doodle-corner{display:none;}}

.boarding-pass{
  background:var(--card); border:1px solid var(--line); border-radius:16px;
  box-shadow:var(--shadow); display:flex; position:relative;
  font-family:var(--font-mono);
}
.bp-main{flex:1; padding:20px 18px;}
.bp-row{display:flex; justify-content:space-between; gap:10px; margin-bottom:12px;}
.bp-field{flex:1;}
.bp-field .lbl{font-size:.62rem; letter-spacing:1px; color:var(--ink-soft); display:block; margin-bottom:3px;}
.bp-field .val{font-size:.92rem; font-weight:700; color:var(--ink);}
.bp-route{display:flex; align-items:center; gap:10px; font-size:1.05rem; font-weight:700; margin-bottom:14px;}
.bp-route .plane{color:var(--coral);}
.bp-stub{
  width:96px; flex-shrink:0; border-left:2px dashed var(--line);
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  gap:6px; padding:10px 6px; position:relative;
}
.bp-stub::before, .bp-stub::after{
  content:''; position:absolute; width:18px; height:18px; background:var(--paper);
  border-radius:50%; left:-10px;
}
.bp-stub::before{top:-9px;}
.bp-stub::after{bottom:-9px;}
.bp-stub .seat{font-size:1.3rem; font-weight:700; color:var(--coral-deep); writing-mode:vertical-rl; letter-spacing:2px;}
.bp-stub .seat-lbl{font-size:.55rem; color:var(--ink-soft); letter-spacing:1px;}

.board-wrap{margin:54px auto 0; max-width:640px; text-align:center;}
.board-label{
  font-family:var(--font-mono); font-size:.72rem; letter-spacing:2px;
  color:var(--ink-soft); display:flex; align-items:center; justify-content:center; gap:8px;
  margin-bottom:14px; text-transform:uppercase;
}
.dot-live{width:7px; height:7px; border-radius:50%; background:var(--teal); animation:pulse 1.6s infinite;}
@keyframes pulse{0%,100%{opacity:1;} 50%{opacity:.25;}}

.flip-board{
  display:flex; justify-content:center; gap:10px; flex-wrap:wrap;
}
.flip-unit{
  background:var(--ink); border-radius:14px; padding:14px 10px 10px;
  min-width:78px; box-shadow:var(--shadow); position:relative; overflow:hidden;
}
.flip-unit::after{content:''; position:absolute; left:0; right:0; top:50%; height:1px; background:rgba(255,255,255,.12);}
.flip-unit .num{
  font-family:var(--font-mono); font-weight:700; font-size:clamp(1.8rem,5vw,2.5rem);
  color:var(--gold-tint); min-width:2.1ch; display:inline-block; text-align:center;
  transition:transform .25s,opacity .25s;
}
.flip-unit .num.tick{transform:translateY(-3px) scale(1.05); opacity:.7;}
.flip-unit .unit-lbl{
  display:block; font-size:.6rem; letter-spacing:1.5px; color:rgba(255,255,255,.55);
  margin-top:4px; text-transform:uppercase;
}
.board-note{font-size:.86rem; color:var(--ink-soft); margin-top:18px;}
.departed-msg{
  font-family:var(--font-display); font-size:1.6rem; color:var(--coral-deep);
  background:var(--coral-tint); border-radius:16px; padding:24px; display:none;
}

/* ============ ITINERARIO ============ */
.section-head{margin-bottom:18px;}
.section-head h2{
  font-family:var(--font-display); font-size:clamp(1.7rem,4vw,2.3rem); margin:0 0 4px;
}
.section-head p{color:var(--ink-soft); margin:0; font-size:.95rem;}

.chips{display:flex; gap:8px; flex-wrap:wrap; margin:18px 0 26px;}
.chip{
  border:1.5px solid var(--line); background:var(--card); border-radius:999px;
  padding:7px 14px; font-size:.84rem; font-weight:600; cursor:pointer;
  display:flex; align-items:center; gap:7px; color:var(--ink-soft);
  transition:all .15s;
}
.chip .dot{width:9px; height:9px; border-radius:50%;}
.chip[aria-pressed="true"]{
  border-color:var(--chip-color); color:var(--ink); background:var(--chip-tint);
}
.chip[data-c="espana"]{--chip-color:var(--gold); --chip-tint:var(--gold-tint);}
.chip[data-c="portugal"]{--chip-color:var(--coral); --chip-tint:var(--coral-tint);}
.chip[data-c="caboverde"]{--chip-color:var(--teal); --chip-tint:var(--teal-tint);}
.chip[data-c="espana"] .dot{background:var(--gold);}
.chip[data-c="portugal"] .dot{background:var(--coral);}
.chip[data-c="caboverde"] .dot{background:var(--teal);}
.chip[data-c="todos"] .dot{background:var(--ink-soft);}

.timeline{list-style:none; margin:0; padding:0; position:relative;}
.timeline::before{
  content:''; position:absolute; left:34px; top:6px; bottom:6px; width:2px;
  background:repeating-linear-gradient(to bottom, var(--line) 0 6px, transparent 6px 12px);
}
@media (min-width:640px){.timeline::before{left:42px;}}
.timeline-item{display:flex; gap:14px; margin-bottom:22px; position:relative;}
.timeline-item.is-hidden{display:none;}
.day-badge{
  flex-shrink:0; width:68px; height:68px; border-radius:50%;
  background:var(--paper); border:2.5px solid var(--tag-color);
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  z-index:1; position:relative;
}
@media (min-width:640px){.day-badge{width:84px; height:84px;}}
.day-badge .day-num{font-family:var(--font-display); font-weight:800; font-size:1.5rem; line-height:1;}
.day-badge .day-date{font-size:.62rem; color:var(--ink-soft); letter-spacing:.4px; margin-top:1px;}
.timeline-item[data-country="espana"] .day-badge{--tag-color:var(--gold);}
.timeline-item[data-country="portugal"] .day-badge{--tag-color:var(--coral);}
.timeline-item[data-country="caboverde"] .day-badge{--tag-color:var(--teal);}

.day-card{
  flex:1; background:var(--card); border:1px solid var(--line); border-radius:var(--radius);
  padding:16px 18px; box-shadow:0 6px 18px -10px rgba(32,48,61,.25); min-width:0;
}
.day-card-head{display:flex; justify-content:space-between; align-items:flex-start; gap:10px; margin-bottom:10px;}
.day-card-head h3{font-family:var(--font-display); font-size:1.15rem; margin:0; font-weight:700;}
.kind-pill{
  font-size:.7rem; font-weight:700; padding:4px 10px; border-radius:999px;
  white-space:nowrap; background:var(--tint-color); color:var(--text-color);
}
.timeline-item[data-country="espana"] .kind-pill{--tint-color:var(--gold-tint); --text-color:var(--gold-deep);}
.timeline-item[data-country="portugal"] .kind-pill{--tint-color:var(--coral-tint); --text-color:var(--coral-deep);}
.timeline-item[data-country="caboverde"] .kind-pill{--tint-color:var(--teal-tint); --text-color:var(--teal-deep);}

.legs{display:flex; flex-direction:column; gap:7px; margin-bottom:6px;}
.leg{display:flex; align-items:center; gap:8px; flex-wrap:wrap; font-size:.88rem;}
.leg-icon{font-size:1rem;}
.leg-text{font-weight:600;}
.leg-meta{color:var(--ink-soft); font-size:.82rem;}
.leg-chip{
  background:rgba(32,48,61,.07); border-radius:999px; padding:2px 9px; font-size:.74rem;
  font-family:var(--font-mono);
}
.leg-tag{
  background:var(--ink); color:var(--gold-tint); border-radius:999px; padding:2px 9px;
  font-size:.7rem; font-family:var(--font-mono);
}
.leg-link{font-size:.78rem; font-weight:700; text-decoration:none; color:var(--coral-deep); white-space:nowrap;}
.leg-link:hover{text-decoration:underline;}

.day-note{
  font-style:italic; color:var(--ink-soft); font-size:.86rem; margin:8px 0;
  border-left:2px solid var(--line); padding-left:10px;
}
.hotel-row{
  border-top:1px dashed var(--line); margin-top:10px; padding-top:10px;
  display:flex; justify-content:space-between; gap:10px; flex-wrap:wrap; font-size:.85rem;
}
.hotel-main strong{color:var(--ink);}
.hotel-meta{display:flex; gap:8px; flex-wrap:wrap; align-items:center;}
.hotel-price{font-family:var(--font-mono); font-size:.78rem; background:rgba(32,48,61,.07); padding:2px 8px; border-radius:999px;}
.hotel-status{font-size:.74rem; font-weight:700; color:var(--coral-deep); background:var(--coral-tint); padding:2px 9px; border-radius:999px;}
.hotel-row.hotel-repeat{color:var(--ink-soft); font-size:.83rem;}
.repeat-tag{font-size:.7rem; color:var(--ink-soft); font-style:italic;}

.extra-box{
  margin-top:10px; border:1px dashed var(--line); border-radius:12px; padding:8px 12px;
  background:repeating-linear-gradient(135deg, rgba(32,48,61,.025) 0 10px, transparent 10px 20px);
}
.extra-box summary{cursor:pointer; font-weight:700; font-size:.86rem; color:var(--teal-deep);}
.extra-box ul{margin:8px 0 2px; padding-left:20px; font-size:.85rem; color:var(--ink-soft);}
.extra-box li{margin-bottom:4px;}

.budget-card{
  margin-top:34px; background:var(--card); border:1px solid var(--line); border-radius:var(--radius);
  padding:20px; box-shadow:0 6px 18px -10px rgba(32,48,61,.25);
}
.budget-card h3{font-family:var(--font-display); margin:0 0 4px; font-size:1.3rem;}
.budget-card .sub{color:var(--ink-soft); font-size:.85rem; margin:0 0 14px;}
.table-scroll{overflow-x:auto;}
table.budget{width:100%; border-collapse:collapse; font-size:.88rem; min-width:420px;}
table.budget th{
  text-align:left; font-size:.72rem; letter-spacing:.6px; color:var(--ink-soft);
  text-transform:uppercase; padding:8px 10px; border-bottom:2px solid var(--line);
}
table.budget td{padding:8px 10px; border-bottom:1px solid var(--line);}
table.budget td:nth-child(2), table.budget td:nth-child(3), table.budget th:nth-child(2), table.budget th:nth-child(3){
  font-family:var(--font-mono); text-align:right; white-space:nowrap;
}
table.budget tfoot td{font-weight:700; border-bottom:none; padding-top:12px;}
.budget-note{font-size:.78rem; color:var(--ink-soft); margin-top:10px;}

/* ============ CHECKLIST ============ */
.progress-card{
  background:var(--card); border:1px solid var(--line); border-radius:var(--radius);
  padding:18px 20px; box-shadow:0 6px 18px -10px rgba(32,48,61,.25); margin-bottom:24px;
}
.progress-top{display:flex; justify-content:space-between; align-items:center; gap:10px; flex-wrap:wrap; margin-bottom:10px;}
#progress-text{font-weight:700; font-family:var(--font-mono); font-size:.9rem;}
#progress-msg{font-family:var(--font-hand); font-size:1.25rem; color:var(--teal-deep);}
.reset-btn{
  border:1.5px solid var(--line); background:transparent; border-radius:999px; padding:6px 14px;
  font-size:.78rem; font-weight:700; color:var(--ink-soft); cursor:pointer;
}
.reset-btn:hover{border-color:var(--coral); color:var(--coral-deep);}
.progress-track{height:10px; border-radius:999px; background:rgba(32,48,61,.08); overflow:hidden;}
.progress-fill{height:100%; width:0%; background:linear-gradient(90deg,var(--teal),var(--gold)); transition:width .4s ease;}

.checklist-grid{display:grid; grid-template-columns:repeat(2,1fr); gap:18px; align-items:start;}
@media (max-width:680px){.checklist-grid{grid-template-columns:1fr;}}
.cat-card{
  background:var(--card); border:1px solid var(--line); border-radius:var(--radius);
  padding:16px 18px; box-shadow:0 6px 18px -10px rgba(32,48,61,.22);
}
.cat-head{display:flex; align-items:center; gap:8px; margin-bottom:10px;}
.cat-emoji{font-size:1.2rem;}
.cat-head h3{font-family:var(--font-display); font-size:1.05rem; margin:0; flex:1;}
.cat-count{font-family:var(--font-mono); font-size:.74rem; color:var(--ink-soft); background:rgba(32,48,61,.07); padding:2px 8px; border-radius:999px;}
.group-label{
  font-size:.7rem; letter-spacing:1px; text-transform:uppercase; color:var(--teal-deep);
  margin:14px 0 6px; font-weight:700; border-bottom:1px solid var(--line); padding-bottom:3px;
}
.group-label:first-child{margin-top:0;}
.check-item{display:flex; align-items:flex-start; gap:10px; padding:5px 2px; cursor:pointer; font-size:.9rem; position:relative;}
.check-item input{position:absolute; inset:0; opacity:0; margin:0; cursor:pointer; z-index:2;}
.check-item .box{
  width:19px; height:19px; border:2px solid var(--line); border-radius:6px; flex-shrink:0;
  margin-top:1px; position:relative; transition:all .15s; background:var(--paper);
}
.check-item input:checked + .box{background:var(--teal); border-color:var(--teal);}
.check-item input:checked + .box::after{
  content:''; position:absolute; left:5px; top:1px; width:5px; height:9px;
  border:solid white; border-width:0 2px 2px 0; transform:rotate(40deg);
}
.check-item input:focus-visible + .box{outline:3px solid var(--coral); outline-offset:2px;}
.check-item .lbl{transition:color .15s, opacity .15s;}
.check-item input:checked ~ .lbl{color:var(--ink-soft); text-decoration:line-through; opacity:.7;}

#confetti-layer{position:fixed; inset:0; pointer-events:none; z-index:200; overflow:hidden;}
.confetti-piece{
  position:absolute; top:-30px; font-size:1.4rem; will-change:transform,opacity;
  animation:fall linear forwards;
}
@keyframes fall{
  to{transform:translateY(110vh) rotate(380deg); opacity:.2;}
}

footer.site-footer{
  text-align:center; padding:30px 18px 50px; color:var(--ink-soft); font-size:.82rem;
}
footer.site-footer .hand{font-family:var(--font-hand); font-size:1.3rem; color:var(--coral-deep); display:block; margin-bottom:4px;}
</style>
</head>
<body>

<header class="site">
  <div class="header-inner">
    <div class="brand-row">
      <div class="brand"><span class="flag">🏝️</span> Cabo Verde Bidaia</div>
      <div class="mini-countdown" id="mini-cd" title="Días para el despegue">🛫 <b id="mini-cd-days">--</b> días</div>
    </div>
    <nav class="tabs" role="tablist" aria-label="Secciones">
      <button role="tab" id="tab-btn-portada" aria-controls="panel-portada" aria-selected="true" data-tab="portada">🛫 Embarque</button>
      <button role="tab" id="tab-btn-itinerario" aria-controls="panel-itinerario" aria-selected="false" data-tab="itinerario" tabindex="-1">🗺️ Itinerario</button>
      <button role="tab" id="tab-btn-checklist" aria-controls="panel-checklist" aria-selected="false" data-tab="checklist" tabindex="-1">🎒 Maleta</button>
    </nav>
  </div>
</header>

<main>

  <!-- ============ PORTADA ============ -->
  <section class="panel active" id="panel-portada" role="tabpanel" aria-labelledby="tab-btn-portada">
    <div class="hero-frame">
      <img src="data:image/jpeg;base64," alt="Las cinco amigas sonriendo y compartiendo un postre, ilustración colorida con flores y doodles">
    </div>

    <div class="title-block">
      <h1>CABO VERDE <span>BIDAIA</span></h1>
      <svg class="underline-doodle" viewBox="0 0 420 26" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M4 18C40 4 80 26 120 14C160 2 200 24 240 12C280 0 320 22 360 10C380 5 400 12 416 8" stroke="#E8536F" stroke-width="4" stroke-linecap="round"/>
      </svg>
      <p class="tagline">5 amigas · 3 países · 14 días de aventura</p>
    </div>

    <div class="ticket-wrap">
      <svg class="doodle-corner tl" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M30 6C40 6 50 14 50 26C50 38 38 44 30 38" stroke="#1C9C8E" stroke-width="3.5" stroke-linecap="round"/>
        <circle cx="9" cy="10" r="2.4" fill="#EFA431"/>
        <circle cx="14" cy="48" r="2" fill="#8C5FBF"/>
      </svg>
